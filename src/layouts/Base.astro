---
import "../styles/base.css";
const {
  title = "RCPN — Resistencia Civil Pacífica",
  description = "Memoria y acción pacífica. Únete y comparte.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08121a" />
    <meta property="og:image:type" content="image/png" />
    <link rel="canonical" href="https://rcpn.me/" />

    <!-- CSP ajustada para permitir scripts inline y JSON-LD -->
    <meta
      http-equiv="Content-Security-Policy"
      content="
        default-src 'self';
        img-src 'self' data:;
        script-src 'self' 'unsafe-inline';
        style-src 'self' 'unsafe-inline';
        connect-src 'self' https://api.counterapi.dev;
        object-src 'none';
        base-uri 'self';
        upgrade-insecure-requests
      "
    />

    <meta name="referrer" content="no-referrer" />

    <!-- Open Graph / Social -->
    <meta property="og:title" content="Resistencia Civil Pacífica Nacional (RCPN)" />
    <meta property="og:description" content="Movimiento ciudadano que promueve la memoria, el respeto y la acción no violenta en México." />
    <meta property="og:url" content="https://rcpn.me/" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://rcpn.me/images/icon-192.png" />

    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/images/icon-192.png" />

    <!-- ✅ Datos estructurados Schema.org (Organization) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Resistencia Civil Pacífica Nacional",
      "alternateName": "RCPN",
      "url": "https://rcpn.me",
      "logo": "https://rcpn.me/images/icon-192.png",
      "description": "La Resistencia Civil Pacífica Nacional (RCPN) es una red de ciudadanos que promueve la memoria, el respeto y la acción no violenta en México."
    }
    </script>
  </head>

  <body>
    <header><slot name="header" /></header>

    <main><slot /></main>

    <!-- Footer global con contador -->
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="brand-dot" aria-hidden="true">●</span>
        <span>Visitas totales: <strong id="contador-visitas">—</strong></span>
      </div>
    </footer>

    <!-- SW opcional -->
    <script>
      if ("serviceWorker" in navigator) {
        addEventListener("load", () =>
          navigator.serviceWorker.register("/sw.js").catch(() => {})
        );
      }
    </script>

    <!-- Contador de visitas (CounterAPI) -->
    <script>
      (async () => {
        const el = document.getElementById("contador-visitas");
        if (!el) return;

        const KEY = "rcpn_counter_counted_session";
        const API = "https://api.counterapi.dev/v1/rcpn/rcpn-page-views";
        try {
          const already = sessionStorage.getItem(KEY) === "1";
          const url = API + (already ? "" : "/incr");
          const r = await fetch(url, { method: "GET", cache: "no-store" });
          if (!r.ok) throw new Error("counter fetch failed");
          const data = await r.json();
          const count = data.count ?? data.value ?? data.total ?? null;
          if (count == null) throw new Error("unexpected response");
          if (!already) sessionStorage.setItem(KEY, "1");
          el.textContent = Number(count).toLocaleString("es-MX");
        } catch (e) {
          console.warn("CounterAPI error:", e);
          el.textContent = "—";
        }
      })();
    </script>

    <style>
      :root {
        --text: #eef6f8;
        --muted: #9aa6b2;
        --accent: #ff7a59;
        --card: #0f1720;
      }
      .site-footer {
        margin-top: 28px;
        padding: 14px 0;
        background: var(--card);
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .footer-inner {
        width: min(1100px, 96vw);
        margin: 0 auto;
        color: var(--muted);
        font-size: 0.95rem;
        display: flex;
        gap: 0.6rem;
        align-items: center;
        justify-content: center;
      }
      .brand-dot { color: var(--accent); font-weight: 900; line-height: 1; }
      .footer-inner strong { color: var(--accent); }
    </style>
  </body>
</html>
