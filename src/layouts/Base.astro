---
import "../styles/base.css";
const { title = 'RCPN — Resistencia Civil Pacífica',
        description = 'Memoria y acción pacífica. Únete y comparte.' } = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#08121a" />
  <!-- CSP mínima (por meta): -->
  <meta http-equiv="Content-Security-Policy"
        content="default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests" />
  <meta name="referrer" content="no-referrer" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" href="/images/icon-192.png" />
</head>
<body>
  <header><slot name="header" /></header>
  <main id="contenido"><slot /></main>
  <footer><slot name="footer" /></footer>
  <script>
    if ('serviceWorker' in navigator) {
      addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(()=>{}));
    }
  </script>
</body>
</html>
