---
import "../styles/base.css";
const {
  title = "RCPN — Resistencia Civil Pacífica",
  description = "Memoria y acción pacífica. Únete y comparte.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1,viewport-fit=cover"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08121a" />

    <!-- CSP: habilitamos fetch a CounterAPI -->
    <meta
      http-equiv="Content-Security-Policy"
      content="
      default-src 'self';
      img-src 'self' data:;
      script-src 'self';
      style-src 'self' 'unsafe-inline';
      connect-src 'self' https://api.counterapi.dev;
      object-src 'none';
      base-uri 'self';
      upgrade-insecure-requests
    "
    />
    <meta name="referrer" content="no-referrer" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <meta
      name="description"
      content="La Resistencia Civil Pacífica Nacional (RCPN) es una red de ciudadanos que promueve la memoria, el respeto y la acción no violenta en México. Únete y participa en nuestro movimiento por la justicia y la paz."
    />
    <meta
      name="keywords"
      content="Resistencia Civil Pacífica Nacional, RCPN, activismo pacífico, derechos civiles, acción ciudadana, memoria y respeto, México"
    />
    <meta name="author" content="Resistencia Civil Pacífica Nacional (RCPN)" />
    <meta
      property="og:title"
      content="Resistencia Civil Pacífica Nacional (RCPN)"
    />
    <meta
      property="og:description"
      content="Movimiento ciudadano que promueve la memoria, el respeto y la acción no violenta en México."
    />
    <meta property="og:url" content="https://rcpn.me/" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://rcpn.me/logo.png" />

    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/images/icon-192.png" />
  </head>
  <footer
    style="margin:20px auto;max-width:1100px;padding:12px 16px;
               color:var(--muted);border-top:1px solid rgba(255,255,255,.06);"
  >
    <p style="text-align:center;margin:0;">
      <span style="color:var(--accent);font-size:1.1rem;">•</span>
      &nbsp;Visitas totales:&nbsp;<strong id="contador-visitas">—</strong>
    </p>
  </footer>

  <!-- Script local, permitido por tu CSP ('self') -->
  <script type="module" src="/counter.js"></script>

  <body>
    <header><slot name="header" /></header>

    <main><slot /></main>

    <!-- Footer global con contador -->
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="brand-dot" aria-hidden="true">●</span>
        <span>Visitas totales: <strong id="contador-visitas">—</strong></span>
      </div>
    </footer>

    <!-- SW (opcional) -->
    <script>
      if ("serviceWorker" in navigator) {
        addEventListener("load", () =>
          navigator.serviceWorker.register("/sw.js").catch(() => {}),
        );
      }
    </script>

    <!-- Contador (CounterAPI) - 1 vez por sesión -->
    <script>
      (async () => {
        const el = document.getElementById("contador-visitas");
        if (!el) return;

        const KEY = "rcpn_counter_counted_session";
        const API = "https://api.counterapi.dev/v1/rcpn/rcpn-page-views";
        try {
          const already = sessionStorage.getItem(KEY) === "1";
          const url = API + (already ? "" : "/incr");
          const r = await fetch(url, { method: "GET", cache: "no-store" });
          if (!r.ok) throw new Error("counter fetch failed");
          const data = await r.json();
          const count = data.count ?? data.value ?? data.total ?? null;
          if (count == null) throw new Error("unexpected response");
          if (!already) sessionStorage.setItem(KEY, "1");
          el.textContent = Number(count).toLocaleString("es-MX");
        } catch (e) {
          console.warn("CounterAPI error:", e);
          el.textContent = "—";
        }
      })();
    </script>

    <style>
      :root {
        --text: #eef6f8;
        --muted: #9aa6b2;
        --accent: #ff7a59;
        --card: #0f1720;
      }
      .site-footer {
        margin-top: 28px;
        padding: 14px 0;
        background: var(--card);
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .footer-inner {
        width: min(1100px, 96vw);
        margin: 0 auto;
        color: var(--muted);
        font-size: 0.95rem;
        display: flex;
        gap: 0.6rem;
        align-items: center;
        justify-content: center;
      }
      .brand-dot {
        color: var(--accent);
        font-weight: 900;
        line-height: 1;
      }
      .footer-inner strong {
        color: var(--accent);
      }
    </style>
  </body>

</html>
