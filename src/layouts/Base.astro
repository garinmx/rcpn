---
import "../styles/base.css";

const {
  title = "RCPN — Resistencia Civil Pacífica",
  description = "Memoria y acción pacífica. Únete y comparte.",
  canonical = "https://rcpn.me/",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08121a" />
    <link rel="canonical" href={canonical} />

    <!-- CSP: permite JSON-LD y scripts inline que ya usas -->
    <meta
      http-equiv="Content-Security-Policy"
      content="
        default-src 'self';
        img-src 'self' data:;
        script-src 'self' 'unsafe-inline';
        style-src 'self' 'unsafe-inline';
        connect-src 'self' https://api.counterapi.dev;
        object-src 'none';
        base-uri 'self';
        upgrade-insecure-requests
      "
    />

    <meta name="referrer" content="no-referrer" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <!-- ⚠️ Asegúrate de tener /public/images/og-image.png (1200x630) -->
    <meta property="og:image" content="https://rcpn.me/images/og-image.png?v=1" />
    <meta property="og:image:secure_url" content="https://rcpn.me/images/og-image.png?v=1" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Resistencia Civil Pacífica Nacional — Memoria • Respeto • Acción no violenta" />

    <!-- Twitter / WhatsApp cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://rcpn.me/images/og-image.png?v=1" />

    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/favicon.svg" />

    <!-- Schema.org (Organization) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Resistencia Civil Pacífica Nacional",
      "alternateName": "RCPN",
      "url": "https://rcpn.me",
      "logo": "https://rcpn.me/favicon.svg",
      "description": "La Resistencia Civil Pacífica Nacional (RCPN) es una red de ciudadanos que promueve la memoria, el respeto y la acción no violenta en México."
    }
    </script>

    <style>
      html, body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        background: linear-gradient(180deg,#0a151e,#08121a);
        overflow-x: hidden;
        box-sizing: border-box;
      }
      main {
        margin: 40px 0 36px 0;
        min-height: calc(100vh - 76px);
      }
    </style>
  </head>
  <body>
    <header>
      <slot name="header" />
    </header>
    <main>
      <slot />
    </main>
    <!-- Service Worker opcional -->
    <script>
      if ("serviceWorker" in navigator) {
        addEventListener("load", () =>
          navigator.serviceWorker.register("/sw.js").catch(() => {})
        );
      }
    </script>
  </body>
</html>
