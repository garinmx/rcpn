---
import Base from "../../layouts/Base.astro";
---
<Base title="Kit de acción — RCPN">
  <main class="section">
    <h1 class="title" style="text-align:center;">Kit de acción</h1>

    <!-- Aviso legal -->
    <p style="text-align:center; font-size:0.95rem; color:#9aa6b2; margin:0.4rem 0 1.2rem;">
      <em>Los logotipos oficiales son de uso restringido. Solicita autorización antes de emplearlos en materiales propios.</em>
    </p>

    <p class="lede">
      Recursos simbólicos y prácticos para fortalecer la Resistencia Civil Pacífica. Todo el material promueve la acción <strong>no violenta</strong>.
    </p>

    <!-- ===================== 1) MATERIALES SIMBÓLICOS ===================== -->
    <h2 class="title" style="text-align:center; font-size:1.4rem; margin-top:2rem;">1) Materiales simbólicos</h2>
    <ul class="cards">
      <!-- Playera -->
      <li>
        <h3>👕 Playera tipo polo (negra)</h3>
        <p>Uniforme simbólico: color negro, logotipo RCPN al frente.</p>
        <picture>
          <source srcset="/kit/playera-rcpn.webp" type="image/webp" />
          <img
            src="/kit/playera-rcpn.png"
            alt="Previsualización playera polo RCPN"
            loading="lazy"
            width="360"
            height="460"
            class="card-img no-save"
            draggable="false"
            oncontextmenu="return false"
            style="user-select:none;-webkit-user-drag:none;-webkit-touch-callout:none"
          />
        </picture>
        <div class="actions" style="display:flex;gap:.6rem;flex-wrap:wrap;margin-top:.6rem">
          <!-- Sin descarga directa de logotipos -->
          <a class="btn" href="https://forms.gle/REEMPLAZA" target="_blank" rel="noopener">Solicitar uso del logotipo</a>
          <a class="btn ghost" href="mailto:hola@rcpn.me?subject=Solicitud%20de%20logotipo%20RCPN">Contactar</a>
        </div>
      </li>

      <!-- Gorra -->
      <li>
        <h3>🧢 Gorra (negra)</h3>
        <p>Gorra negra con logotipo RCPN al frente.</p>
        <picture>
          <source srcset="/kit/gorra-rcpn.webp" type="image/webp" />
          <img
            src="/kit/gorra-rcpn.png"
            alt="Previsualización gorra RCPN"
            loading="lazy"
            width="360"
            height="360"
            class="card-img no-save"
            draggable="false"
            oncontextmenu="return false"
            style="user-select:none;-webkit-user-drag:none;-webkit-touch-callout:none"
          />
        </picture>
        <div class="actions" style="display:flex;gap:.6rem;flex-wrap:wrap;margin-top:.6rem">
          <!-- Sin descarga directa de logotipos -->
          <a class="btn" href="https://forms.gle/REEMPLAZA" target="_blank" rel="noopener">Solicitar uso del logotipo</a>
          <a class="btn ghost" href="mailto:hola@rcpn.me?subject=Solicitud%20de%20logotipo%20RCPN">Contactar</a>
        </div>
      </li>
    </ul>

    <!-- ===================== 2) RECURSOS GRÁFICOS Y DE DIFUSIÓN ===================== -->
    <h2 class="title" style="text-align:center; font-size:1.4rem; margin-top:2.5rem;">2) Recursos gráficos y de difusión</h2>
    <ul class="cards">
      <!-- Flyer A4 -->
      <li>
        <h3>📘 Flyer A4 (imprimir)</h3>
        <p>Cartel vertical con mensaje de unión.</p>
        <picture>
          <source srcset="/kit/flyer-a4.webp" type="image/webp" />
          <img
            src="/kit/flyer-a4.png"
            alt="Vista previa del flyer A4 de RCPN"
            loading="lazy"
            class="card-img"
          />
        </picture>
        <div class="actions" style="display:flex;gap:.6rem;flex-wrap:wrap;margin-top:.6rem">
          <a class="btn" href="/kit/flyer-a4.webp" download="rcpn-flyer-a4.webp">Descargar WebP</a>
          <a class="btn ghost" href="/kit/flyer-a4.png" download="rcpn-flyer-a4.png">Descargar PNG</a>
          <a class="btn ghost" href="/kit/flyer-a4.pdf" download="rcpn-flyer-a4.pdf">Descargar PDF</a>
        </div>
      </li>

      <!-- Post 1:1 -->
      <li>
        <h3>🟧 Post 1:1 (1080×1080)</h3>
        <p>Formato cuadrado optimizado para redes.</p>
        <picture>
          <source srcset="/kit/post-cuadrado.webp" type="image/webp" />
          <img
            src="/kit/post-cuadrado.png"
            alt="Vista previa del post cuadrado 1080×1080"
            loading="lazy"
            class="card-img"
          />
        </picture>
        <div class="actions" style="display:flex;gap:.6rem;flex-wrap:wrap;margin-top:.6rem">
          <a class="btn" href="/kit/post-cuadrado.webp" download="rcpn-post-1080.webp">Descargar WebP</a>
          <a class="btn ghost" href="/kit/post-cuadrado.png" download="rcpn-post-1080.png">Descargar PNG</a>
        </div>
      </li>

      <!-- Banner OG -->
      <li>
        <h3>🖼 Banner OG (1200×630)</h3>
        <p>Imagen para previsualización al compartir enlaces.</p>
        <picture>
          <source srcset="/kit/banner-og.webp" type="image/webp" />
          <img
            src="/kit/banner-og.png"
            alt="Vista previa del banner Open Graph 1200×630"
            loading="lazy"
            class="card-img"
          />
        </picture>
        <div class="actions" style="display:flex;gap:.6rem;flex-wrap:wrap;margin-top:.6rem">
          <a class="btn" href="/kit/banner-og.webp" download="rcpn-banner-og.webp">Descargar WebP</a>
          <a class="btn ghost" href="/kit/banner-og.png" download="rcpn-banner-og.png">Descargar PNG</a>
        </div>
      </li>

      <!-- QR oficial -->
      <li>
        <h3>🔗 QR oficial</h3>
        <p>Código QR a <code>https://rcpn.me</code>.</p>
        <picture>
          <source srcset="/kit/qr-rcpn.webp" type="image/webp" />
          <img
            src="/kit/qr-rcpn.png"
            alt="QR oficial hacia rcpn.me"
            loading="lazy"
            class="card-img card-qr"
          />
        </picture>
        <div class="actions" style="display:flex;gap:.6rem;flex-wrap:wrap;margin-top:.6rem">
          <a class="btn" href="/kit/qr-rcpn.webp" download="qr-rcpn.webp">Descargar WebP</a>
          <a class="btn ghost" href="/kit/qr-rcpn.png" download="qr-rcpn.png">Descargar PNG</a>
          <a class="btn ghost" href="/kit/qr-rcpn.svg" download="qr-rcpn.svg">Descargar SVG
