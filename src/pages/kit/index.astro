---
import Base from "../../layouts/Base.astro";

const FORM_URL =
  "https://docs.google.com/forms/d/e/1FAIpQLSe466qRdPcIIwJP5ZpdVqS5wmfPyRAZGUx8-o0u1Izwb8vw8A/viewform?usp=header";
---

<Base title="Kit de acción — RCPN">
  <main class="section">
    <h1 class="title" style="text-align:center;">Kit de acción</h1>

    <!-- Aviso legal -->
    <p style="text-align:center; font-size:0.95rem; color:#9aa6b2; margin:0.4rem 0 1.2rem;">
      <em>Los logotipos oficiales son de uso restringido. Solicita autorización antes de emplearlos en materiales propios.</em>
    </p>

    <p class="lede">
      Recursos simbólicos y prácticos para fortalecer la Resistencia Civil Pacífica. Todo el material promueve la acción <strong>no violenta</strong>.
    </p>

    <!-- ===================== 1) MATERIALES SIMBÓLICOS ===================== -->
    <h2 class="title" style="text-align:center; font-size:1.4rem; margin-top:2rem;">1) Materiales simbólicos</h2>
    <ul class="cards">
      <!-- Playera -->
      <li style="position: relative;">
        <h3>👕 Playera tipo polo (negra)</h3>
        <p>Uniforme simbólico: color negro, logotipo RCPN al frente.</p>
        <picture style="position:relative; display:block;">
          <source srcset="/kit/playera-rcpn.webp" type="image/webp" />
          <img
            src="/kit/playera-rcpn.png"
            alt="Previsualización playera polo RCPN"
            loading="lazy"
            width="360"
            height="460"
            class="card-img no-save"
            draggable="false"
            oncontextmenu="return false"
            style="user-select:none;-webkit-user-drag:none;-webkit-touch-callout:none"
          />
          <div class="actions actions-overlay-special">
            <a class="btn" href={FORM_URL} target="_blank" rel="noopener">Solicitar uso del logotipo</a>
            <a class="btn ghost" href={FORM_URL} target="_blank" rel="noopener">Contactar</a>
          </div>
        </picture>
      </li>

      <!-- Gorra -->
      <li style="position: relative;">
        <h3>🧢 Gorra (negra)</h3>
        <p>Gorra negra con logotipo RCPN al frente.</p>
        <picture style="position:relative; display:block;">
          <source srcset="/kit/gorra-rcpn.webp" type="image/webp" />
          <img
            src="/kit/gorra-rcpn.png"
            alt="Previsualización gorra RCPN"
            loading="lazy"
            width="360"
            height="360"
            class="card-img no-save"
            draggable="false"
            oncontextmenu="return false"
            style="user-select:none;-webkit-user-drag:none;-webkit-touch-callout:none"
          />
          <div class="actions actions-overlay-special">
            <a class="btn" href={FORM_URL} target="_blank" rel="noopener">Solicitar uso del logotipo</a>
            <a class="btn ghost" href={FORM_URL} target="_blank" rel="noopener">Contactar</a>
          </div>
        </picture>
      </li>
    </ul>

    <!-- ... resto del contenido sin cambios ... -->

  </main>

  <style>
    .card-img {
      display: block;
      max-width: 100%;
      height: auto;
      border-radius: 12px;
      object-fit: contain;
      background: #0d141b;
    }
    .card-qr {
      max-width: 280px;
    }
    .no-save {
      position: relative;
    }
    .no-save::after {
      content: "";
      position: absolute;
      inset: 0;
      background: transparent;
    }

    .actions {
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      margin-top: 0.6rem;
      width: 100%;
      box-sizing: border-box;
      padding-left: 16px;
      padding-right: 16px;
    }
    .btn,
    .btn.ghost {
      margin: 0 auto;
      min-width: 120px;
      max-width: 340px;
      text-align: center;
      box-sizing: border-box;
    }

    .actions-overlay-special {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      background: rgba(15, 23, 32, 0.5);
      padding: 10px 16px;
      box-sizing: border-box;
      display: flex;
      justify-content: center;
      gap: 10px;
      border-radius: 0 0 var(--radius) var(--radius);
      transition: background-color 0.3s ease;
    }

    .actions-overlay-special:hover {
      background: rgba(15, 23, 32, 0.85);
    }

    .actions-overlay-special .btn,
    .actions-overlay-special .btn.ghost {
      flex: 1;
      margin: 0;
      padding: 12px 0;
      min-width: unset;
      max-width: 100%;
      text-align: center;
      background-color: transparent;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    .actions-overlay-special .btn:hover {
      background-color: var(--accent);
      color: #fff;
    }

    .actions-overlay-special .btn.ghost:hover {
      background-color: rgba(255, 122, 89, 0.15);
      color: var(--accent);
    }
  </style>
</Base>
