---
/** Archivo: src/pages/protocolos/index.astro */
import Base from "../../layouts/Base.astro";
const CANONICAL = "https://www.rcpn.me/protocolos/";
---

<Base
  title="Protocolos de seguridad | Resistencia Civil Pacífica Nacional"
  description="Lineamientos de cuidado físico, emocional y digital para acciones pacíficas y organización comunitaria."
  canonical={CANONICAL}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="og:title" content="Protocolos de seguridad | RCPN" />
    <meta property="og:description" content="Buenas prácticas para cuidar a las personas y comunidades en acciones pacíficas." />
    <meta property="og:url" content={CANONICAL} />
    <meta property="og:image" content="https://www.rcpn.me/og-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json">
      {JSON.stringify({
        "@context":"https://schema.org",
        "@type":"BreadcrumbList",
        "itemListElement":[
          {"@type":"ListItem","position":1,"name":"Inicio","item":"https://www.rcpn.me/"},
          {"@type":"ListItem","position":2,"name":"Protocolos","item":CANONICAL}
        ]
      })}
    </script>
  </Fragment>

  <main class="page">
    <header class="page__header">
      <nav class="breadcrumbs" aria-label="Ruta de navegación">
        <a href="/">Inicio</a> <span>›</span> <strong>Protocolos</strong>
      </nav>
      <h1>Protocolos de seguridad y cuidado</h1>
      <p class="lede">Lineamientos prácticos para planear, ejecutar y documentar acciones no violentas con cuidado integral.</p>
    </header>

    <section class="content-block">
      <h2>Antes de la acción</h2>
      <ul>
        <li>Definir objetivos, roles y canales de comunicación.</li>
        <li>Evaluar riesgos y puntos de contacto de emergencia.</li>
        <li>Revisar permisos y normatividad local.</li>
        <li>Capacitaciones básicas: observación, de–escalamiento y primeros auxilios.</li>
      </ul>
      <h2>Durante la acción</h2>
      <ul>
        <li>Lenguaje y conducta no violenta; registrar incidentes con discreción.</li>
        <li>Respeto a vecinos y espacios; rutas de salida seguras.</li>
        <li>Equipo de cuidado: agua, botiquín, contactos de apoyo.</li>
      </ul>
      <h2>Después de la acción</h2>
      <ul>
        <li>Evaluación breve: aprendizajes, mejoras y documentación.</li>
        <li>Seguimiento a personas vulnerables y resguardo de datos.</li>
        <li>Comunicación transparente de resultados.</li>
      </ul>
      <p>
        Refuerza tu privacidad con la <a href="/seguridad-digital">guía de seguridad digital</a> y revisa los
        <a href="/principios">principios</a> que fundamentan estos protocolos.
      </p>
    </section>

    <section class="content-block cta-block">
      <h2>¿Quieres adaptarlos a tu comunidad?</h2>
      <p>
        Podemos orientar a tu equipo local. Completa el formulario:
        <a class="btn" href="https://forms.gle/HB1WZJiXCBcJq5eg8" target="_blank" rel="noopener noreferrer">Quiero participar</a>
      </p>
    </section>
  </main>

  <style>
    .page{min-height:100vh;display:flex;flex-direction:column;align-items:center}
    .page__header{max-width:760px;margin:2rem auto 1rem;padding:0 1rem;text-align:center}
    .breadcrumbs{font-size:.95rem;opacity:.9;margin-bottom:.6rem}.breadcrumbs a{border-bottom:1px dashed var(--accent);text-decoration:none}
    .content-block{max-width:760px;margin:1.6rem auto;padding:0 1rem}
    .cta-block .btn{display:inline-block;margin-left:.4rem;background:var(--accent);color:#fff;padding:.6rem 1rem;border-radius:10px;text-decoration:none;font-weight:700}
    @media (max-width:900px){.page__header,.content-block{max-width:96vw;padding:0 .6rem}}
  </style>
</Base>
