---
import Base from "../layouts/Base.astro";
---

<Base
  title="Resistencia Civil Pacífica Nacional | Acción pacífica en México"
  description="Somos una red ciudadana que promueve la memoria, el respeto y la acción no violenta para construir un México pacífico. Únete y participa en nuestras iniciativas."
  canonical="https://www.rcpn.me/"
>
  <main class="home">
    <header class="home__header">
      <h1 class="title">Resistencia Civil Pacífica Nacional</h1>
      <p class="lede">
        Somos una red de ciudadanos que exige memoria, respeto y soluciones pacíficas. Únete y comparte para construir un México más justo y en paz.
      </p>
      <p>
        Nuestro movimiento promueve acciones pacíficas, respeto por los derechos humanos y la defensa de la justicia social a través de la colaboración y la resistencia civil no violenta.
      </p>
      <div class="cta">
        <a class="btn" href="/kit/" title="Consulta el Kit de acción para activistas pacíficos">Kit de acción</a>
        <a class="btn ghost" href="/seguridad-digital/" title="Aprende sobre seguridad digital para activistas">Seguridad digital</a>
      </div>
    </header>

    <!-- Añadido sección con enlaces internos para mejorar enlazado SEO -->
    <section aria-label="Recursos principales de la Resistencia Civil Pacífica Nacional" class="resources-links" style="max-width:750px; margin:2rem auto; padding:0 1rem;">
      <h2>Recursos y Guías Importantes</h2>
      <ul>
        <li><a href="/kit/" title="Ver Kit de acción RCPN con recursos para la acción pacífica">Kit de acción: materiales y protocolos para fortalecer la resistencia civil pacífica.</a></li>
        <li><a href="/seguridad-digital/" title="Guía práctica sobre seguridad digital para activistas">Seguridad digital: guía para proteger tus comunicaciones y dispositivos durante la acción pacífica.</a></li>
      </ul>
    </section>

    <!-- Carrusel de imágenes -->
    <section aria-label="Galería de acciones de la Resistencia Civil Pacífica Nacional" class="carousel">
      <div class="carousel-container">
        <button class="carousel-button prev" aria-label="Imagen anterior">❮</button>
        <div class="carousel-track-container">
          <ul class="carousel-track">
            {Array.from({ length: 10 }, (_, i) => (
              <li class="carousel-slide" key={i}>
                <img src={`/images/action${i + 1}.jpg`} alt={`Acción Resistencia Civil Pacífica ${i + 1}`} loading="lazy" />
              </li>
            ))}
          </ul>
        </div>
        <button class="carousel-button next" aria-label="Imagen siguiente">❯</button>
      </div>
    </section>

    <!-- Footer local debajo del carrusel -->
    <footer class="site-footer" style="margin-top:3rem;">
      <div class="footer-inner">
        <span style="color:#ff7a59; font-weight:900;">•</span>
        © 2025 Resistencia Civil Pacífica Nacional
      </div>
    </footer>
  </main>

  <style>
    /* El estilo existente se mantiene igual */
    /* Puedes mantener el CSS proporcionado inicialmente */
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      let currentIndex = 0;
      const track = document.querySelector('.carousel-track');
      const slides = Array.from(track.children);
      const prevButton = document.querySelector('.carousel-button.prev');
      const nextButton = document.querySelector('.carousel-button.next');
      let interval;

      function updateCarousel() {
        const slideWidth = slides[0].getBoundingClientRect().width;
        const amountToMove = slideWidth * currentIndex;
        track.style.transform = `translateX(-${amountToMove}px)`;
      }

      function nextSlide() {
        currentIndex = currentIndex === slides.length - 1 ? 0 : currentIndex + 1;
        updateCarousel();
      }

      function prevSlide() {
        currentIndex = currentIndex === 0 ? slides.length - 1 : currentIndex - 1;
        updateCarousel();
      }

      function startAutoSlide() {
        clearInterval(interval);
        interval = setInterval(nextSlide, 3000);
      }

      prevButton.addEventListener('click', () => {
        prevSlide();
        startAutoSlide();
      });

      nextButton.addEventListener('click', () => {
        nextSlide();
        startAutoSlide();
      });

      window.addEventListener('resize', updateCarousel);
      updateCarousel();
      startAutoSlide();
    });
  </script>
</Base>
