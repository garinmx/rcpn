---
import Base from "../layouts/Base.astro";
---

<Base
  title="Resistencia Civil Pacífica Nacional (RCPN) | Movimiento ciudadano por la acción pacífica en México"
>
  <main class="home">
    <header class="home__header">
      <h1 class="title">Resistencia Civil Pacífica Nacional</h1>
      <p class="lede">
        Somos una red de ciudadanos que exige memoria, respeto y soluciones
        pacíficas. Únete y comparte.
      </p>
      <div class="cta">
        <a class="btn" href="/kit/">Kit de acción</a>
        <a class="btn ghost" href="/seguridad-digital/">Seguridad digital</a>
      </div>
    </header>

    <!-- Carrusel de imágenes -->
    <section aria-label="Galería de acciones de la Resistencia Civil Pacífica Nacional" class="carousel">
      <div class="carousel-container">
        <button class="carousel-button prev" aria-label="Imagen anterior">❮</button>
        <div class="carousel-track-container">
          <ul class="carousel-track">
            {Array.from({ length: 10 }, (_, i) => (
              <li class="carousel-slide" key={i}>
                <img src={`/images/action${i + 1}.jpg`} alt={`Acción Resistencia Civil Pacífica ${i + 1}`} loading="lazy" />
              </li>
            ))}
          </ul>
        </div>
        <button class="carousel-button next" aria-label="Imagen siguiente">❯</button>
      </div>
    </section>

    <!-- Hero ÚNICO: SVG responsivo sin recortes -->
    <section aria-label="Imagen de portada" class="hero-box" style="margin-top:2rem;">
      <svg
        class="hero-svg"
        viewBox="0 0 1600 900"
        preserveAspectRatio="xMidYMid meet"
        role="img"
        aria-label="RCPN — Resistencia Civil Pacífica. Memoria, Respeto, Acción no violenta."
      >
        <defs>
          <radialGradient id="g1" cx="50%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#101b24"></stop>
            <stop offset="60%" stop-color="#0c131a"></stop>
            <stop offset="100%" stop-color="#0a1117"></stop>
          </radialGradient>
        </defs>
        <rect width="1600" height="900" fill="url(#g1)"></rect>
        <text
          x="50%"
          y="45%"
          text-anchor="middle"
          font-size="74"
          font-weight="800"
          fill="#ff7a59"
          style="letter-spacing:.02em;"
        >
          RCPN — Resistencia Civil Pacífica Nacional
        </text>
        <text
          x="50%"
          y="55%"
          text-anchor="middle"
          font-size="30"
          fill="#e9f2f5"
          opacity=".90"
        >
          Memoria • Respeto • Acción no violenta
        </text>
        <rect
          x="520"
          y="57%"
          width="560"
          height="6"
          fill="#ff7a59"
          rx="3"
          opacity=".85"></rect>
      </svg>
    </section>
  </main>

  <style>
    .carousel {
      width: 100%;
      max-width: 700px;
      margin: 3rem auto;
      position: relative;
      overflow: visible;
      background: none;
    }
    .carousel-container {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .carousel-track-container {
      overflow: hidden;
      width: 100%;
      border-radius: 16px;
    }
    .carousel-track {
      display: flex;
      transition: transform 0.3s ease-in-out;
      padding: 0;
      margin: 0;
      list-style: none;
    }
    .carousel-slide {
      min-width: 100%;
      box-sizing: border-box;
      padding: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
    }
    .carousel-slide img {
      width: 100%;
      max-width: 450px;
      max-height: 450px;
      margin: auto;
      border-radius: 16px;
      object-fit: contain;
      box-shadow: 0 4px 15px rgba(0,0,0,0.2);
      background: #131a22;
      border: 4px solid #22262a;
    }
    .carousel-button {
      background: #fff;
      color: var(--accent);
      font-size: 3rem;
      padding: 0 18px;
      border: none;
      border-radius: 50%;
      cursor: pointer;
      box-shadow: 0 2px 8px rgba(0,0,0,0.12);
      transition: background 0.25s, color 0.25s;
      z-index: 11;
      outline: 2px solid var(--accent);
    }
    .carousel-button:hover {
      background: var(--accent);
      color: #fff;
    }
    .carousel-button:focus {
      outline: 2px solid darkorange;
    }
    .carousel-button.prev {
      position: absolute;
      left: -60px;
      top: 50%;
      transform: translateY(-50%);
    }
    .carousel-button.next {
      position: absolute;
      right: -60px;
      top: 50%;
      transform: translateY(-50%);
    }
    @media (max-width: 700px) {
      .carousel {
        max-width: 98vw;
        margin: 2rem auto;
      }
      .carousel-slide img {
        max-width: 98vw;
        max-height: 48vw;
        border-radius: 10px;
      }
      .carousel-button.prev, .carousel-button.next {
        left: 0;
        right: 0;
        font-size: 2rem;
        padding: 0 12px;
      }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      let currentIndex = 0;
      const track = document.querySelector('.carousel-track');
      const slides = Array.from(track.children);
      const prevButton = document.querySelector('.carousel-button.prev');
      const nextButton = document.querySelector('.carousel-button.next');
      let interval;

      function updateCarousel() {
        const slideWidth = slides[0].getBoundingClientRect().width;
        const amountToMove = slideWidth * currentIndex;
        track.style.transform = `translateX(-${amountToMove}px)`;
      }

      function nextSlide() {
        currentIndex = currentIndex === slides.length - 1 ? 0 : currentIndex + 1;
        updateCarousel();
      }

      function prevSlide() {
        currentIndex = currentIndex === 0 ? slides.length - 1 : currentIndex - 1;
        updateCarousel();
      }

      function startAutoSlide() {
        clearInterval(interval);
        interval = setInterval(nextSlide, 3000);
      }

      prevButton.addEventListener('click', () => {
        prevSlide();
        startAutoSlide();
      });

      nextButton.addEventListener('click', () => {
        nextSlide();
        startAutoSlide();
      });

      window.addEventListener('resize', updateCarousel);
      updateCarousel();
      startAutoSlide();
    });
  </script>
</Base>
