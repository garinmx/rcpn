---
// Archivo: src/pages/index.astro
import Base from "../layouts/Base.astro";
import { Fragment } from "astro/jsx-runtime";
---

<Base
  title="Resistencia Civil Pacífica Nacional | Acción pacífica en México"
  description="Somos una red ciudadana que promueve memoria, respeto y acción no violenta en México. Únete y participa en nuestras iniciativas pacíficas."
  canonical="https://www.rcpn.me/"
>
  <Fragment slot="head">
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Resistencia Civil Pacífica Nacional | Acción pacífica en México" />
    <meta property="og:description" content="Movimiento ciudadano que promueve la acción no violenta, la memoria y la participación activa para construir un México más justo." />
    <meta property="og:url" content="https://www.rcpn.me/" />
    <meta property="og:image" content="https://www.rcpn.me/images/og-image.png" />
    <meta property="og:site_name" content="RCPN" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Resistencia Civil Pacífica Nacional | Acción pacífica en México" />
    <meta name="twitter:description" content="Acción no violenta, memoria y participación ciudadana para transformar México." />
    <meta name="twitter:image" content="https://www.rcpn.me/images/og-image.png" />

    <!-- Apple Touch Icon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </Fragment>

  <!-- ░░ Modal “Día de Muertos” (1 vez por sesión) ░░ -->
  <div id="dm-overlay" class="dm-overlay" hidden aria-hidden="true">
    <div class="dm-modal" role="dialog" aria-modal="true" aria-label="Invitación RCPN — Día de Muertos">
      <button class="dm-close" type="button" aria-label="Cerrar invitación">×</button>

      <a class="dm-link" href="/kit/" aria-label="Ir al detalle del evento">
        <img
          class="dm-img"
          src=""
          alt="RCPN — Día de Muertos para Niños"
          width="1200"
          height="1200"
          loading="eager"
        />
      </a>
      <p class="dm-note">
        <a href="/kit/">Ver más detalles</a>
      </p>
    </div>
  </div>

  <main class="home">
    <header class="home__header">
      <h1 class="title">Resistencia Civil Pacífica Nacional</h1>
      <p class="lede">
        Somos una red de ciudadanos que exige memoria, respeto y soluciones pacíficas. Únete y comparte para construir un México más justo y en paz.
      </p>
      <p>
        Nuestro movimiento promueve acciones pacíficas, respeto por los derechos humanos y la defensa de la justicia social mediante la colaboración y la resistencia civil no violenta.
      </p>
      <div class="cta">
        <a class="btn" href="/kit/" title="Consulta el Kit de acción para activistas pacíficos">Kit de acción</a>
        <a class="btn ghost" href="/seguridad-digital/" title="Aprende sobre seguridad digital para activistas">Seguridad digital</a>
      </div>
    </header>

    <!-- ... toda la estructura y contenido que ya tienes ... -->

    <!-- Aquí mantén los mismos sections, carousel, footer exactamente igual -->
    <!-- ... -->

  </main>

  <style>
    /* ========== MODAL DÍA DE MUERTOS ========== */
    .dm-overlay {
      position: fixed;
      inset: 0;
      display: grid;
      place-items: center;
      background: rgba(0,0,0,.72);
      z-index: 9999;
      padding: clamp(10px, 3vw, 24px);
      backdrop-filter: blur(2px);
    }
    .dm-modal {
      position: relative;
      max-width: min(95vw, 840px);
      width: 100%;
      border-radius: 16px;
      box-shadow: 0 30px 100px rgba(0,0,0,.55);
      overflow: hidden;
      background: #0f1720;
      border: 1px solid rgba(255,255,255,.08);
      transform: translateZ(0);
    }
    .dm-img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
      background: #111;
      aspect-ratio: 1/1;
    }
    .dm-close {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 44px;
      height: 44px;
      line-height: 44px;
      border-radius: 50%;
      border: 0;
      background: #ffffff;
      color: #111827;
      font-size: 28px;
      font-weight: 700;
      cursor: pointer;
      display: grid;
      place-items: center;
      box-shadow: 0 6px 20px rgba(0,0,0,.35);
      transition: transform .15s ease, background .2s ease, color .2s ease;
      z-index: 2;
    }
    .dm-close:hover { transform: scale(1.05); background:#111827; color:#fff; }
    .dm-note {
      text-align: center;
      margin: 10px 0 14px;
      font-size: .95rem;
      color: #cbd5e1;
    }
    .dm-note a { color: var(--accent, #ff7a59); text-decoration: underline; }
    /* ... Igual todo tu CSS ... */
  </style>

  <script is:inline>
    // ===== Modal “Día de Muertos” (1 vez por sesión) =====
    document.addEventListener('DOMContentLoaded', () => {
      const overlay = document.getElementById('dm-overlay');
      if (!overlay) return;

      const modal = overlay.querySelector('.dm-modal');
      const closeBtn = overlay.querySelector('.dm-close');
      const modalImg = overlay.querySelector('.dm-img');
      const IMG_PATH = '/images/dia-de-muertos.jpg';
      const SEEN_KEY = 'dm_seen_2025';

      function showOverlay() {
        overlay.hidden = false;
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        closeBtn?.focus();
      }
      function hideOverlay() {
        overlay.hidden = true;
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        sessionStorage.setItem(SEEN_KEY, '1');
      }
      // Mostrar solo si no se ha visto en esta sesión
      if (!sessionStorage.getItem(SEEN_KEY)) {
        const img = new window.Image();
        img.src = IMG_PATH;
        img.onload = () => {
          if (modalImg) modalImg.src = IMG_PATH;
          showOverlay();
        };
        img.onerror = () => {
          // si fallara la imagen, no bloqueamos la navegación
          sessionStorage.setItem(SEEN_KEY, '1');
        };
      }
      // Cerrar con botón, click fuera o tecla Escape
      closeBtn?.addEventListener('click', hideOverlay);
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) hideOverlay();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay.hidden === false) hideOverlay();
      });
      // Evita scroll de fondo
      overlay.addEventListener('wheel', (e) => { if (!overlay.hidden) e.preventDefault(); }, { passive:false });
      overlay.addEventListener('touchmove', (e) => { if (!overlay.hidden) e.preventDefault(); }, { passive:false });
    });
    // ===== Carrusel =====
    document.addEventListener('DOMContentLoaded', () => {
      const track = document.querySelector('.carousel-track');
      if (!track) return;
      let currentIndex = 0;
      const slides = Array.from(track.children);
      const prevButton = document.querySelector('.carousel-button.prev');
      const nextButton = document.querySelector('.carousel-button.next');
      let interval;
      function updateCarousel() {
        const slideWidth = slides[0].getBoundingClientRect().width;
        track.style.transform = `translateX(-${slideWidth * currentIndex}px)`;
      }
      function nextSlide() {
        currentIndex = currentIndex === slides.length - 1 ? 0 : currentIndex + 1;
        updateCarousel();
      }
      function prevSlide() {
        currentIndex = currentIndex === 0 ? slides.length - 1 : currentIndex - 1;
        updateCarousel();
      }
      function startAutoSlide() {
        clearInterval(interval);
        interval = setInterval(nextSlide, 3000);
      }
      prevButton?.addEventListener('click', () => { prevSlide(); startAutoSlide(); });
      nextButton?.addEventListener('click', () => { nextSlide(); startAutoSlide(); });
      window.addEventListener('resize', updateCarousel);
      updateCarousel();
      startAutoSlide();
    });
  </script>
</Base>
