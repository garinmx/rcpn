---
import Base from "../layouts/Base.astro";
---

<Base
  title="Resistencia Civil Pacífica Nacional (RCPN) | Movimiento ciudadano por la acción pacífica en México"
>
  <main class="home">
    <header class="home__header">
      <h1 class="title">Resistencia Civil Pacífica Nacional</h1>
      <p class="lede">
        Somos una red de ciudadanos que exige memoria, respeto y soluciones
        pacíficas. Únete y comparte.
      </p>
      <div class="cta">
        <a class="btn" href="/kit/">Kit de acción</a>
        <a class="btn ghost" href="/seguridad-digital/">Seguridad digital</a>
      </div>
    </header>

    <!-- Carrusel de imágenes -->
    <section aria-label="Galería de acciones de la Resistencia Civil Pacífica Nacional" class="carousel">
      <div class="carousel-container">
        <button class="carousel-button prev" aria-label="Imagen anterior">&#10094;</button>
        <div class="carousel-track-container">
          <ul class="carousel-track">
            {Array.from({ length: 10 }, (_, i) => (
              <li class="carousel-slide" key={i}>
                <img src={`/images/action${i + 1}.jpg`} alt={`Acción Resistencia Civil Pacífica ${i + 1}`} />
              </li>
            ))}
          </ul>
        </div>
        <button class="carousel-button next" aria-label="Imagen siguiente">&#10095;</button>
      </div>
    </section>

    <!-- Hero ÚNICO: SVG responsivo sin recortes -->
    <section aria-label="Imagen de portada" class="hero-box" style="margin-top:2rem;">
      <svg
        class="hero-svg"
        viewBox="0 0 1600 900"
        preserveAspectRatio="xMidYMid meet"
        role="img"
        aria-label="RCPN — Resistencia Civil Pacífica. Memoria, Respeto, Acción no violenta."
      >
        <defs>
          <radialGradient id="g1" cx="50%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#101b24"></stop>
            <stop offset="60%" stop-color="#0c131a"></stop>
            <stop offset="100%" stop-color="#0a1117"></stop>
          </radialGradient>
        </defs>
        <rect width="1600" height="900" fill="url(#g1)"></rect>
        <!-- Título -->
        <text
          x="50%"
          y="45%"
          text-anchor="middle"
          font-size="74"
          font-weight="800"
          fill="#ff7a59"
          style="letter-spacing:.02em;"
        >
          RCPN — Resistencia Civil Pacífica Nacional
        </text>
        <!-- Subtítulo -->
        <text
          x="50%"
          y="55%"
          text-anchor="middle"
          font-size="30"
          fill="#e9f2f5"
          opacity=".90"
        >
          Memoria • Respeto • Acción no violenta
        </text>
        <!-- Línea decorativa -->
        <rect
          x="520"
          y="57%"
          width="560"
          height="6"
          fill="#ff7a59"
          rx="3"
          opacity=".85"></rect>
      </svg>
    </section>
  </main>

  <style>
    .carousel {
      width: 100%;
      max-width: 1100px;
      margin: 2rem auto;
      position: relative;
      overflow: hidden;
    }
    .carousel-container {
      display: flex;
      align-items: center;
      position: relative;
    }
    .carousel-track-container {
      overflow: hidden;
      width: 100%;
    }
    .carousel-track {
      display: flex;
      transition: transform 0.3s ease-in-out;
      padding: 0;
      margin: 0;
      list-style: none;
    }
    .carousel-slide {
      min-width: 100%;
      box-sizing: border-box;
      padding: 8px;
    }
    .carousel-slide img {
      width: 100%;
      border-radius: 12px;
      object-fit: cover;
      box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }
    .carousel-button {
      background-color: var(--accent);
      border: none;
      color: white;
      font-size: 2rem;
      cursor: pointer;
      padding: 0 12px;
      border-radius: 50%;
      user-select: none;
      transition: background-color 0.3s;
    }
    .carousel-button:hover {
      background-color: darkorange;
    }
    .carousel-button:focus {
      outline: 2px solid white;
    }
    .carousel-button.prev {
      position: absolute;
      left: -40px;
      top: 50%;
      transform: translateY(-50%);
    }
    .carousel-button.next {
      position: absolute;
      right: -40px;
      top: 50%;
      transform: translateY(-50%);
    }
  </style>

  <script>
    let currentIndex = 0;

    const track = document.querySelector('.carousel-track');
    const slides = Array.from(track.children);
    const prevButton = document.querySelector('.carousel-button.prev');
    const nextButton = document.querySelector('.carousel-button.next');

    function updateCarousel() {
      const slideWidth = slides[0].getBoundingClientRect().width;
      const amountToMove = slideWidth * currentIndex;
      track.style.transform = `translateX(-${amountToMove}px)`;
    }

    prevButton.addEventListener('click', () => {
      currentIndex = currentIndex === 0 ? slides.length - 1 : currentIndex - 1;
      updateCarousel();
    });

    nextButton.addEventListener('click', () => {
      currentIndex = currentIndex === slides.length - 1 ? 0 : currentIndex + 1;
      updateCarousel();
    });

    // Inicializa
    updateCarousel();
  </script>
</Base>
